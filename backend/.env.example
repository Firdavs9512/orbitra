# Orbitra Configuration
# Copy this file to .env and customize the values for your deployment
# Environment variables take precedence over orbitra.config.ts

# ===================================
# Server Configuration
# ===================================

# Port the server will listen on
# Default: 3000
ORBITRA_PORT=3000

# ===================================
# Database Configuration
# ===================================

# Database provider: 'sqlite' or 'clickhouse'
# Default: sqlite
ORBITRA_DB_PROVIDER=sqlite

# SQLite configuration (when ORBITRA_DB_PROVIDER=sqlite)
# Path to SQLite database file
# Default: ./data/orbitra.db
ORBITRA_DB_SQLITE_PATH=./data/orbitra.db

# ClickHouse configuration (when ORBITRA_DB_PROVIDER=clickhouse)
# ClickHouse server host
# Default: localhost
ORBITRA_DB_CLICKHOUSE_HOST=localhost

# ClickHouse server port
# Default: 8123
ORBITRA_DB_CLICKHOUSE_PORT=8123

# ClickHouse database name
# Default: orbitra
ORBITRA_DB_CLICKHOUSE_DATABASE=orbitra

# ClickHouse username
# Default: default
ORBITRA_DB_CLICKHOUSE_USERNAME=default

# ClickHouse password
# Default: (empty)
ORBITRA_DB_CLICKHOUSE_PASSWORD=

# ===================================
# Redis Configuration
# ===================================

# Redis connection URL (for pub/sub and sessions)
# Default: redis://localhost:6379
ORBITRA_REDIS_URL=redis://localhost:6379

# ===================================
# Authentication
# ===================================

# JWT secret key for signing tokens
# IMPORTANT: Change this in production!
# Default: change-me-in-production
ORBITRA_JWT_SECRET=your-secret-key-here

# ===================================
# CORS Configuration
# ===================================

# Allowed CORS origins (comma-separated list)
# Use '*' to allow all origins (not recommended for production)
# For production, specify exact origins: https://yourdomain.com,https://app.yourdomain.com
# Default: *
ORBITRA_CORS_ORIGINS=*

# Allow credentials (cookies, authorization headers) in CORS requests
# When origins is '*', credentials should be false for browser compatibility
# When specific origins are set, can be true for cookie/auth support
# Default: true
ORBITRA_CORS_CREDENTIALS=true

# ===================================
# Default Admin User Seeder
# ===================================
# These credentials are used to create an admin user on first startup
# when the database has 0 users. CHANGE THESE IMMEDIATELY AFTER FIRST LOGIN!

# Default admin email address
# Default: admin@orbitra.sh
ORBITRA_ADMIN_EMAIL=admin@orbitra.sh

# Default admin password
# IMPORTANT: Change this immediately after first login!
# Default: changeme
ORBITRA_ADMIN_PASSWORD=changeme

# Default admin full name
# Default: Admin
ORBITRA_ADMIN_NAME=Admin

# ===================================
# Legacy Environment Variables
# ===================================
# These are supported for backward compatibility but ORBITRA_ prefix is recommended

# PORT=3000
# DATABASE_PROVIDER=sqlite
# REDIS_URL=redis://localhost:6379
# JWT_SECRET=your-secret-key
# CORS_ORIGINS=*
# CORS_CREDENTIALS=true
